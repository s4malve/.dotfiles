{
    "label" : "lock",
    "action" : "swayidle -w timeout 1 'swaylock -f' timeout 60 'hyprctl dispatch dpms off' resume 'hyprctl dispatch dpms on' before-sleep 'swaylock - f'",
    "text" : "Lock"
}

{
    "label" : "logout",
    "action" : "hyprctl dispatch exit 0",
    "text" : "Logout"
}

{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Shutdown"
}

{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspend"
}

{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reboot"
}
